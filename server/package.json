{
  "name": "taskteam-server",
  "version": "1.0.0",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test:docker-up": "docker-compose -f docker-compose.test.yaml up -d",
    "test:docker-down": "docker-compose -f docker-compose.test.yaml down",
    "test:migrate": "dotenv -e .env.test -- npx drizzle-kit push",
    "pretest": "npm run test:docker-up && sleep 3 && npm run test:migrate",
    "test": "dotenv -e .env.test -- vitest run",
    "posttest": "npm run test:docker-down",
    "db:push": "npx drizzle-kit push",
    "db:studio": "npx drizzle-kit studio",
    "db:seed": "dotenv -e .env -- ts-node src/db/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "pg": "^8.11.3",
    "resend": "^6.9.4",
    "socket.io": "^4.7.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.37",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.4",
    "@types/supertest": "^7.2.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.x.x",
    "vitest": "^4.1.0"
  }
}
